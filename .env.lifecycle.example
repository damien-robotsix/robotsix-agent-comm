# ---------------------------------------------------------------------------
# robotsix-lifecycle environment configuration
# ---------------------------------------------------------------------------
# Copy this file to .env.lifecycle and fill in the values for your deployment.
# Every variable is prefixed with ROBOTSIX_LIFECYCLE_.
# ---------------------------------------------------------------------------

# --- Agent identity ----------------------------------------------------------
# This server's agent ID on the broker.
# ROBOTSIX_LIFECYCLE_AGENT_ID=lifecycle-server

# --- Broker connection -------------------------------------------------------
# Broker hostname.  Default: localhost.
# ROBOTSIX_LIFECYCLE_BROKER_HOST=ai-broker.robotsix.net

# Broker port.  Default: 8443.
# ROBOTSIX_LIFECYCLE_BROKER_PORT=8443

# Broker scheme: "https" (default) or "http".
# ROBOTSIX_LIFECYCLE_BROKER_SCHEME=https

# Bearer token for broker authentication.  Leave unset if the broker
# auth is disabled (development only).
# ROBOTSIX_LIFECYCLE_BROKER_TOKEN=your-agent-token

# Path to a custom CA PEM file for a privately-signed broker certificate.
# When unset the system trust store is used.
# ROBOTSIX_LIFECYCLE_BROKER_TLS_CA=/etc/robotsix/tls/ca.pem

# --- Langfuse tracing --------------------------------------------------------
# Public key for the Langfuse project (pk-...).
# When unset, tracing is disabled — the server operates normally without it.
# ROBOTSIX_LIFECYCLE_LANGFUSE_PUBLIC_KEY=pk-langfuse-...

# Secret key for the Langfuse project (sk-...).
# Required together with the public key to enable tracing.
# ROBOTSIX_LIFECYCLE_LANGFUSE_SECRET_KEY=sk-langfuse-...

# Langfuse host URL.  When unset the Langfuse SDK default is used
# (usually https://cloud.langfuse.com).
# ROBOTSIX_LIFECYCLE_LANGFUSE_HOST=https://cloud.langfuse.com
