# ---------------------------------------------------------------------------
# robotsix-broker environment configuration
# ---------------------------------------------------------------------------
# Copy this file to .env.broker and fill in the values for your deployment.
# Every variable is prefixed with ROBOTSIX_BROKER_ (per ADR 0006 §3.1).
# ---------------------------------------------------------------------------

# --- Listen address --------------------------------------------------------
# Host the broker binds to.  Default: 0.0.0.0 (container-reachable).
# ROBOTSIX_BROKER_HOST=0.0.0.0

# TCP port.  Default: 8443.
# ROBOTSIX_BROKER_PORT=8443

# --- Mode ------------------------------------------------------------------
# "production" (default) or "development".
# - production:  TLS + agent authentication are mandatory.
# - development: plaintext and anonymous access are allowed but emit
#                loud warnings to the log.
# ROBOTSIX_BROKER_ENV=production

# --- TLS -------------------------------------------------------------------
# Path to the server certificate PEM file.
# ROBOTSIX_BROKER_TLS_CERT=/etc/robotsix/tls/server.pem

# Path to the server private key PEM file.
# ROBOTSIX_BROKER_TLS_KEY=/etc/robotsix/tls/server.key

# Path to the CA bundle PEM file (only needed for mutual TLS).
# ROBOTSIX_BROKER_TLS_CA=/etc/robotsix/tls/ca.pem

# Enable mutual TLS (client certificate required).
# Accepted truthy values: 1, true, yes (case-insensitive).  Default: false.
# ROBOTSIX_BROKER_REQUIRE_CLIENT_CERT=false

# --- Agent credentials -----------------------------------------------------
# JSON file mapping agent_id → token, e.g. {"agent-1": "secret-1", ...}.
# When both AGENT_TOKENS_FILE and AGENT_TOKENS are set, the file wins.
# ROBOTSIX_BROKER_AGENT_TOKENS_FILE=/etc/robotsix/broker/agent-tokens.json

# Inline fallback: id1=token1,id2=token2,...
# Only used when AGENT_TOKENS_FILE is NOT set.
# ROBOTSIX_BROKER_AGENT_TOKENS=agent-a=pass-a,agent-b=pass-b

# --- Tuning -----------------------------------------------------------------
# Agent time-to-live in seconds (default: 60).
# ROBOTSIX_BROKER_TTL_SECONDS=60

# Max requests per agent per second (0 = disabled).  Default: 0 (off).
# ROBOTSIX_BROKER_RATE_LIMIT=20.0

# Max HTTP request body size in bytes.  Default: 1_048_576 (1 MiB).
# ROBOTSIX_BROKER_MAX_BODY_SIZE=1048576

# --- Audit ------------------------------------------------------------------
# Path to the audit log file (JSON-lines).  Unset = stdout.
# ROBOTSIX_BROKER_AUDIT_LOG=/var/log/robotsix-broker/audit.log
