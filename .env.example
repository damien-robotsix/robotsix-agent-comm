# ---------------------------------------------------------------------------
# LLM provider configuration
# ---------------------------------------------------------------------------

# Required.  Your LLM provider API key (e.g. an OpenAI / Anthropic key).
LLM_API_KEY=your-api-key-here

# Model name passed to the provider.  Defaults to "gpt-4o-mini".
LLM_MODEL=gpt-4o-mini

# Optional custom base URL for providers that expose an OpenAI-compatible
# endpoint on a different host (e.g. a local Ollama instance).
# Leave empty to use the provider's default.
LLM_BASE_URL=

# ---------------------------------------------------------------------------
# Chat SSE server configuration
# ---------------------------------------------------------------------------

# Host address the server binds to.  Defaults to 127.0.0.1 (localhost only).
SERVER_HOST=127.0.0.1

# Port the server listens on.  Defaults to 8000.
SERVER_PORT=8000

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Python logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL).
# Defaults to INFO.
LOG_LEVEL=INFO
